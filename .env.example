# Application Mode
# Set to "true" to use local Redis and Postgres instead of Upstash/cloud services
LOCAL_MODE=true

# PostgreSQL Database URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sgm_copier

# Local Redis URL (used when LOCAL_MODE=true)
REDIS_URL=redis://localhost:6379/0

# OpenAI API Key (for GPT-based signal parsing)
OPENAI_API_KEY=sk-your-openai-api-key

# Telegram API Credentials (obtain from https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash

# JWT Secret Key for authentication tokens
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Fernet Encryption Key for Telegram session storage (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-encryption-key

# QStash Credentials (used when LOCAL_MODE=false)
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key
QSTASH_URL=https://qstash.upstash.io

# Upstash Redis Credentials (used when LOCAL_MODE=false)
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-redis-token
